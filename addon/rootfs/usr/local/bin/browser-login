#!/usr/bin/env bash
# Thin wrapper around the ez-ui skill's browser-login script.
# Usage:
#   browser-login                    # uses HA_BROWSER_USER / HA_BROWSER_PASS env vars
#   browser-login <username> <pass>  # explicit credentials
set -euo pipefail

exec node /usr/local/lib/ez-ui/browser-login.mjs "$@"
